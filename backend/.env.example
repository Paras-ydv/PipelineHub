# Backend
# Use port 5433 if running postgres via docker-compose (avoids conflict with local postgres on 5432)
DATABASE_URL=postgresql://pipelinehub:pipelinehub_secret@localhost:5433/pipelinehub
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
JWT_SECRET=change-this-to-a-secure-random-string
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
PORT=4000

# For production Redis (Upstash)
# REDIS_HOST=your-upstash-host.upstash.io
# REDIS_PORT=6379
# REDIS_PASSWORD=your-upstash-password
