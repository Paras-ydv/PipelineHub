generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  username     String       @unique
  passwordHash String
  role         UserRole     @default(DEVELOPER)
  avatarUrl    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  repositories Repository[]
  events       Event[]

  @@map("users")
}

model Repository {
  id             String         @id @default(uuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  name           String
  owner          String
  fullName       String         @unique
  branch         String         @default("main")
  language       RepoLanguage   @default(GENERAL)
  githubToken    String?
  webhookId      String?
  webhookSecret  String
  webhookUrl     String?
  isActive       Boolean        @default(true)
  autoDemo       Boolean        @default(false)
  eventTypes     String[]       @default(["push"])
  environment    String         @default("production")
  pipelineConfig Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  jobs           Job[]
  webhookEvents  WebhookEvent[]
  deployments    Deployment[]

  @@map("repositories")
}

model WebhookEvent {
  id           String     @id @default(uuid())
  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id])
  eventType    String
  payload      Json
  signature    String?
  processed    Boolean    @default(false)
  createdAt    DateTime   @default(now())

  @@map("webhook_events")
}

model Pipeline {
  id           String    @id @default(uuid())
  name         String
  repositoryId String?
  stages       Json
  branch       String?
  isDefault    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  jobs         Job[]

  @@map("pipelines")
}

model Job {
  id           String       @id @default(uuid())
  repositoryId String
  repository   Repository   @relation(fields: [repositoryId], references: [id])
  pipelineId   String?
  pipeline     Pipeline?    @relation(fields: [pipelineId], references: [id])
  workerId     String?
  worker       Worker?      @relation(fields: [workerId], references: [id])
  name         String
  branch       String
  commitHash   String?
  commitMsg    String?
  author       String?
  eventType    String
  language     RepoLanguage @default(GENERAL)
  status       JobStatus    @default(QUEUED)
  priority     Int          @default(5)
  currentStage String?
  stages       Json?
  duration     Int?
  retryCount   Int          @default(0)
  maxRetries   Int          @default(3)
  scheduledAt  DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  logs         BuildLog[]

  @@map("jobs")
}

model BuildLog {
  id        String   @id @default(uuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id])
  stage     String
  level     LogLevel @default(INFO)
  message   String
  timestamp DateTime @default(now())

  @@map("build_logs")
}

model Worker {
  id            String       @id @default(uuid())
  name          String       @unique
  language      RepoLanguage
  status        WorkerStatus @default(IDLE)
  currentJobId  String?
  jobsCompleted Int          @default(0)
  jobsFailed    Int          @default(0)
  cpuUsage      Float        @default(0)
  memUsage      Float        @default(0)
  lastHeartbeat DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  jobs          Job[]

  @@map("workers")
}

model Deployment {
  id           String           @id @default(uuid())
  repositoryId String
  repository   Repository       @relation(fields: [repositoryId], references: [id])
  jobId        String?
  environment  String
  version      String
  status       DeploymentStatus @default(PENDING)
  url          String?
  commitHash   String?
  deployedBy   String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime         @default(now())

  @@map("deployments")
}

model Event {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  type      String
  payload   Json
  createdAt DateTime @default(now())

  @@map("events")
}

model QueueMetric {
  id        String   @id @default(uuid())
  queueName String
  waiting   Int      @default(0)
  active    Int      @default(0)
  completed Int      @default(0)
  failed    Int      @default(0)
  delayed   Int      @default(0)
  timestamp DateTime @default(now())

  @@map("queue_metrics")
}

enum UserRole {
  ADMIN
  DEVELOPER
  VIEWER
}

enum RepoLanguage {
  PYTHON
  NODE
  JAVA
  GENERAL
}

enum JobStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
  TIMEOUT
  RETRYING
}

enum WorkerStatus {
  IDLE
  BUSY
  OFFLINE
  ERROR
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

enum DeploymentStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  ROLLED_BACK
}
